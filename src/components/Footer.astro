  <div class="footer-container">
    <div class="footer-left">
      <p class="footer-text">© 2026</p>
      <a href="https://www.inforegister.ee/14401168-NEKMIT-OU/" target="_blank" rel="noopener noreferrer" class="footer-link">
        Nekmit OÜ
      </a>
      <span class="footer-divider">·</span>
      <p class="footer-text">Built with Astro</p>
      <span class="footer-divider">·</span>
      <p class="footer-text">Deployed on Vercel</p>
    </div>

    <div class="footer-right">
      <a href="https://github.com/k1rta" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
        <img src="https://cdn.simpleicons.org/github/888888" alt="GitHub" class="social-icon" />
      </a>
      <a href="https://linkedin.com/in/kirta-linda-karits/" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn">
        <img src="https://cdn.simpleicons.org/linkedin/888888" alt="LinkedIn" class="social-icon" />
      </a>
    </div>
  </div>
