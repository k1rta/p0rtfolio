<style>
  .footer {
    background: var(--color-bg);
  }

  .footer-separator {
    height: 1px;
    background: var(--color-border);
    margin: 0 auto;
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--space-8) clamp(var(--space-4), 4vw, var(--space-8));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .footer-text {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin: 0;
  }

  .footer-link {
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    font-weight: 500;
  }

  .footer-link:hover {
    color: var(--color-accent);
  }

  .footer-divider {
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .footer-right {
    display: flex;
    gap: var(--space-4);
    align-items: center;
  }

  .social-link {
    display: flex;
    align-items: center;
    transition: opacity 0.2s ease;
  }

  .social-link:hover {
    opacity: 1;
  }

  .social-icon {
    width: 20px;
    height: 20px;
    transition: filter 0.2s ease;
  }

  .social-link:hover .social-icon {
    filter: brightness(1.5);
  }

  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
    }

    .footer-left {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
    }

    .footer-divider {
      display: none;
    }

    .footer-right {
      align-self: flex-start;
    }
  }
</style>
