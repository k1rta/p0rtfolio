---
---

<a href="#main-content" class="skip-link">Skip to main content</a>

<nav class="nav" aria-label="Primary" data-testid="nav">
  <div class="nav-container" data-testid="nav-container">
    <!-- Brand Block -->
    <a href="/" class="brand" aria-label="Home" data-testid="nav-logo">
      <div class="brand-icon">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 6L8 26M8 6L24 16M8 16L20 26" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="brand-text">
        <span class="brand-name">Kirta-Linda Karits</span>
        <span class="brand-title">QA Engineer / Test Automation</span>
      </div>
    </a>

    <!-- Nav Rail -->
    <div class="nav-rail">
      <a href="#skills" class="nav-link" data-section="skills" data-testid="nav-link-skills">Skills</a>
      <a href="#experience" class="nav-link" data-section="experience" data-testid="nav-link-experience">Experience</a>
      <a href="#projects" class="nav-link" data-section="projects" data-testid="nav-link-projects">Projects</a>
      <a href="#contact" class="nav-link" data-section="contact" data-testid="nav-link-contact">Contact</a>
    </div>

    <!-- Actions -->
    <div class="nav-actions">
      <div class="availability-badge" data-testid="availability-badge">
        <span class="status-indicator"></span>
        <span class="status-text">Available for work</span>
      </div>

      <button 
        class="mobile-menu-toggle" 
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-testid="mobile-menu-toggle"
      >
        <svg class="icon icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg class="icon icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Drawer -->
  <div id="mobile-menu" class="mobile-menu" hidden data-testid="mobile-menu">
    <div class="mobile-menu-content">
      <nav class="mobile-nav">
        <a href="#skills" class="mobile-link" data-section="skills">Skills</a>
        <a href="#experience" class="mobile-link" data-section="experience">Experience</a>
        <a href="#projects" class="mobile-link" data-section="projects">Projects</a>
        <a href="#contact" class="mobile-link" data-section="contact">Contact</a>
      </nav>

      <div class="mobile-footer">
        <div class="availability-badge" data-testid="availability-badge-mobile">
          <span class="status-indicator"></span>
          <span class="status-text">Available for work</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Backdrop -->
  <div class="mobile-backdrop" hidden data-testid="mobile-backdrop"></div>
</nav>

<style>
  /* Skip Link */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    background: var(--color-accent);
    color: var(--color-bg);
    padding: var(--space-2) var(--space-4);
    text-decoration: none;
    font-weight: 600;
    z-index: 200;
    border-radius: 0 0 var(--radius-md) 0;
    transition: top 0.2s ease;
  }

  .skip-link:focus {
    top: 0;
  }

  /* Nav Container */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: oklch(from var(--color-bg) l c h / 0.9);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 0 0 rgba(0, 0, 0, 0);
    transition: box-shadow 0.2s ease;
  }

  .nav.nav--scrolled {
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
  }

  .nav-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--space-3) clamp(var(--space-4), 4vw, var(--space-8));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
  }

  /* Brand Block */
  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--color-text);
    transition: opacity 0.2s ease;
    flex-shrink: 0;
  }

  .brand:hover {
    opacity: 0.8;
  }

  .brand-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-accent);
    transform: translateY(0);
    transition: all 0.2s ease;
  }

  .brand:hover .brand-icon {
    background: var(--color-surface-2);
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .brand-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.2;
  }

  .brand-title {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-muted);
    line-height: 1.2;
    letter-spacing: 0.01em;
  }

  /* Nav Rail */
  .nav-rail {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: var(--space-1);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  }

  .nav-link {
    position: relative;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-surface-2);
  }

  .nav-link.active {
    color: var(--color-text);
    background: var(--color-bg);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
  }

  /* Actions */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .availability-badge {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text);
    white-space: nowrap;
  }

  .status-indicator {
    width: 7px;
    height: 7px;
    background: var(--color-accent);
    border-radius: 50%;
    box-shadow: 0 0 0 2px rgba(0, 229, 153, 0.2);
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  .status-text {
    color: var(--color-muted);
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }

  /* Mobile Toggle */
  .mobile-menu-toggle {
    display: none;
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-2);
    color: var(--color-muted);
    cursor: pointer;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  .mobile-menu-toggle:hover {
    background: var(--color-surface-2);
    color: var(--color-text);
  }

  .mobile-menu-toggle .icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .mobile-menu-toggle .icon-close {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .mobile-menu-toggle[aria-expanded="true"] .icon-menu {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(-90deg);
  }

  .mobile-menu-toggle[aria-expanded="true"] .icon-close {
    opacity: 1;
    transform: translate(-50%, -50%) rotate(0deg);
  }

  /* Mobile Menu Drawer */
  .mobile-menu {
    position: fixed;
    top: 65px;
    left: 0;
    right: 0;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    max-height: calc(100vh - 65px);
    overflow-y: auto;
    transform: translateY(-100%);
    opacity: 0;
    transition: transform 0.24s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.24s ease;
  }

  .mobile-menu:not([hidden]) {
    transform: translateY(0);
    opacity: 1;
  }

  .mobile-menu-content {
    padding: var(--space-4) clamp(var(--space-4), 4vw, var(--space-6));
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .mobile-link {
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    padding: var(--space-3) var(--space-2);
    border-radius: var(--radius-md);
    border-left: 2px solid transparent;
    transition: all 0.2s ease;
    min-height: 44px;
    display: flex;
    align-items: center;
    letter-spacing: 0.01em;
  }

  .mobile-link:hover {
    color: var(--color-text);
    background: var(--color-surface);
    border-left-color: var(--color-border);
  }

  .mobile-link.active {
    color: var(--color-accent);
    background: var(--color-surface);
    border-left-color: var(--color-accent);
  }

  .mobile-footer {
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .mobile-footer .availability-badge {
    width: 100%;
    justify-content: center;
    padding: var(--space-2) var(--space-3);
  }

  .mobile-footer .status-text {
    color: var(--color-text);
  }

  /* Mobile Backdrop */
  .mobile-backdrop {
    position: fixed;
    top: 65px;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.24s ease;
    pointer-events: none;
  }

  .mobile-backdrop:not([hidden]) {
    opacity: 1;
    pointer-events: auto;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .nav-rail {
      display: none;
    }

    .mobile-menu-toggle {
      display: flex;
    }
  }

  @media (max-width: 640px) {
    .brand-text {
      display: none;
    }

    .nav-actions .availability-badge {
      display: none;
    }

    .nav-container {
      padding: var(--space-3) var(--space-4);
    }
  }
</style>

<script is:inline>
  const mobileMenuToggle = document.querySelector('.mobile-menu-toggle');
  const mobileMenu = document.querySelector('.mobile-menu');
  const mobileBackdrop = document.querySelector('.mobile-backdrop');
  const navLinks = document.querySelectorAll('.nav-link, .mobile-link');

  function closeMobileMenu() {
    if (mobileMenu && mobileMenuToggle && mobileBackdrop) {
      mobileMenu.hidden = true;
      mobileBackdrop.hidden = true;
      mobileMenuToggle.setAttribute('aria-expanded', 'false');
      mobileMenuToggle.setAttribute('aria-label', 'Open menu');
      document.body.style.overflow = '';
    }
  }

  function openMobileMenu() {
    if (mobileMenu && mobileMenuToggle && mobileBackdrop) {
      mobileMenu.hidden = false;
      mobileBackdrop.hidden = false;
      mobileMenuToggle.setAttribute('aria-expanded', 'true');
      mobileMenuToggle.setAttribute('aria-label', 'Close menu');
      document.body.style.overflow = 'hidden';
    }
  }

  function toggleMobileMenu() {
    if (mobileMenu && mobileMenu.hidden) {
      openMobileMenu();
    } else {
      closeMobileMenu();
    }
  }

  if (mobileMenuToggle) {
    mobileMenuToggle.addEventListener('click', toggleMobileMenu);
  }

  if (mobileBackdrop) {
    mobileBackdrop.addEventListener('click', closeMobileMenu);
  }

  document.querySelectorAll('.mobile-link').forEach(function(link) {
    link.addEventListener('click', closeMobileMenu);
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && mobileMenu && !mobileMenu.hidden) {
      closeMobileMenu();
    }
  });

  const mediaQuery = window.matchMedia('(min-width: 901px)');
  function handleViewportChange(e) {
    if (e.matches) {
      closeMobileMenu();
    }
  }
  mediaQuery.addEventListener('change', handleViewportChange);

  const observerOptions = {
    threshold: 0.3,
    rootMargin: '-100px 0px -66% 0px'
  };

  const nav = document.querySelector('.nav');
  const sections = document.querySelectorAll('section[id]');
  let activeSection = null;
  
  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        activeSection = entry.target.id;
      }
    });

    if (activeSection) {
      navLinks.forEach(function(link) {
        if (link.dataset && link.dataset.section === activeSection) {
          link.classList.add('active');
        } else {
          link.classList.remove('active');
        }
      });
    } else {
      navLinks.forEach(function(link) {
        link.classList.remove('active');
      });
    }
  }, observerOptions);

  sections.forEach(function(section) {
    observer.observe(section);
  });

  window.addEventListener('scroll', function() {
    if (nav) {
      if (window.scrollY > 10) {
        nav.classList.add('nav--scrolled');
      } else {
        nav.classList.remove('nav--scrolled');
      }
    }

    if (window.scrollY < 100) {
      activeSection = null;
      navLinks.forEach(function(link) {
        link.classList.remove('active');
      });
    }
  });
</script>
