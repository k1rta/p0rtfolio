---
import { config } from '../config';

const { email, linkedin, github } = config.personal;
---

<section class="contact" id="contact">
  <div class="contact-container">
    <div class="contact-header reveal">
      <p class="section-label">CONTACT</p>
      <h2 class="section-heading">Let's work together</h2>
    </div>

    <div class="contact-card reveal">
      <a href={`mailto:${email}`} class="contact-row">
        <div class="contact-left">
          <img src="https://cdn.simpleicons.org/icloud/888888" alt="Email" class="contact-icon-img" />
          <span class="contact-label">Email</span>
        </div>
        <div class="contact-right">
          <span class="contact-link-text">{email}</span>
          <i data-lucide="arrow-up-right" class="arrow-icon"></i>
        </div>
      </a>

      <a href={linkedin} target="_blank" rel="noopener noreferrer" class="contact-row">
        <div class="contact-left">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#888888" xmlns="http://www.w3.org/2000/svg">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span class="contact-label">LinkedIn</span>
        </div>
        <div class="contact-right">
          <span class="contact-link-text">kirta-linda-karits</span>
          <i data-lucide="arrow-up-right" class="arrow-icon"></i>
        </div>
      </a>

      <a href={github} target="_blank" rel="noopener noreferrer" class="contact-row contact-row-last">
        <div class="contact-left">
          <img src="https://cdn.simpleicons.org/github/888888" alt="GitHub" class="contact-icon-img" />
          <span class="contact-label">GitHub</span>
        </div>
        <div class="contact-right">
          <span class="contact-link-text">k1rta</span>
          <i data-lucide="arrow-up-right" class="arrow-icon"></i>
        </div>
      </a>
    </div>

    <a href={`mailto:${email}`} class="btn-send-email reveal">
      Send Email
    </a>
  </div>
</section>

<style>
  .contact {
    padding: clamp(var(--space-12), 8vw, var(--space-24));
    background: var(--color-bg);
  }

  .contact-container {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .contact-header {
    text-align: center;
  }

  .section-label {
    font-size: var(--text-xs);
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-bottom: var(--space-3);
  }

  .section-heading {
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-3);
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: 1.6;
  }

  .contact-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
  }

  .contact-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: background-color 0.2s ease;
    margin: 0 calc(-1 * var(--space-4));
    padding-left: var(--space-4);
    padding-right: var(--space-4);
    border-radius: var(--radius-md);
  }

  .contact-row:hover {
    background: var(--color-surface-2);
  }

  .contact-row-last {
    border-bottom: none;
  }

  .contact-left {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .contact-icon {
    width: 18px;
    height: 18px;
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .contact-icon-img {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .contact-label {
    font-size: var(--text-base);
    color: var(--color-muted);
    font-weight: 500;
  }

  .contact-right {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .contact-link-text {
    font-size: var(--text-base);
    color: var(--color-accent);
    font-weight: 500;
  }

  .arrow-icon {
    width: 14px;
    height: 14px;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .btn-send-email {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-8);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
    border: 1px solid var(--color-accent);
    background: var(--color-accent);
    color: var(--color-bg);
    margin: var(--space-4) auto 0;
    width: fit-content;
  }

  .btn-send-email:hover {
    background: #00ffb3;
    border-color: #00ffb3;
  }

  @media (max-width: 768px) {
    .section-heading {
      font-size: var(--text-xl);
    }

    .contact-card {
      padding: var(--space-6);
    }

    .btn-send-email {
      width: 100%;
    }

    .contact-row {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
    }

    .contact-right {
      padding-left: calc(18px + var(--space-3));
    }
  }
</style>

<script>
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.contact .reveal').forEach(el => {
    observer.observe(el);
  });

  import('https://unpkg.com/lucide@latest/dist/esm/lucide.js').then((lucide) => {
    lucide.createIcons();
  });
</script>
